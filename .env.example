# Copy to your runtime environment (shell/IDE/container). Do NOT commit secrets.
#
# Required: provide at least one search provider key
SERPER_API_KEY=
TAVILY_API_KEY=
# Alternative: self-hosted SearXNG instance (base URL, e.g. https://searx.example.org)
SEARXNG_BASE_URL=
# Optional SearXNG request settings
# SEARXNG_LANGUAGE=en-US
# SEARXNG_CATEGORIES=general
# SEARXNG_ENGINES=google,bing
# SEARXNG_TIME_RANGE=day
# SEARXNG_SAFESEARCH=1
# SEARXNG_USER_AGENT=
# SEARXNG_HEADERS_JSON={"Authorization":"Bearer ..."}
# SEARXNG_TIMEOUT_SECONDS=30
#
# Optional: GitHub Issues loader (recommended to avoid rate limits)
GITHUB_TOKEN=
#
# Optional: polite API identification (recommended)
WIKIPEDIA_USER_AGENT=kindly-web-search-mcp-server/0.0.1 (contact: you@example.com)
ARXIV_USER_AGENT=kindly-web-search-mcp-server/0.0.1 (contact: you@example.com)
#
# Optional: StackExchange API (higher quota)
STACKEXCHANGE_KEY=
STACKEXCHANGE_FILTER=withbody
#
# Output limits (defaults shown)
STACKEXCHANGE_MAX_CHARS=20000
GITHUB_MAX_CHARS=20000
GITHUB_MAX_COMMENTS=50
WIKIPEDIA_MAX_CHARS=50000
ARXIV_MAX_CHARS=50000
ARXIV_MAX_PAGES=30
#
# Server / transport (used when running HTTP/SSE)
FASTMCP_HOST=127.0.0.1
FASTMCP_PORT=8000
#
# Logging (stderr only; keep stdio clean)
LOG_LEVEL=WARNING

# Output compression (requires: pip install kindly-web-search-mcp-server[compress])
# Reduces token consumption for LLM consumers via caveman-compression.
# Backend auto-detected: openai > mlm > nlp (based on installed deps).
KINDLY_COMPRESS_OUTPUT=0

# Diagnostics (verbose logs + response diagnostics)
KINDLY_DIAGNOSTICS=0

# Tool time budgets (MCP clients may impose their own limits)
KINDLY_TOOL_TOTAL_TIMEOUT_SECONDS=120
KINDLY_TOOL_TOTAL_TIMEOUT_MAX_SECONDS=600
KINDLY_WEB_SEARCH_MAX_CONCURRENCY=3
# If unset or invalid, default concurrency is 3 (clamped 1..5).

# Browser engine selection: "chromium" (default) or "lightpanda"
# LightPanda is a fast headless browser with native CDP support.
# Requires a running LightPanda server (see docker-compose.yml).
KINDLY_BROWSER_ENGINE=chromium
# LightPanda connection (only used when KINDLY_BROWSER_ENGINE=lightpanda)
KINDLY_LIGHTPANDA_HOST=127.0.0.1
KINDLY_LIGHTPANDA_PORT=9222

# Browser automation (required for universal HTML loading via nodriver)
# If nodriver cannot auto-detect a browser, set an explicit binary path:
# - WSL/Ubuntu example: /usr/bin/chromium
KINDLY_BROWSER_EXECUTABLE_PATH=

# Universal HTML loader timeout + nodriver startup retries (helps with cold starts, especially Snap Chromium)
KINDLY_HTML_TOTAL_TIMEOUT_SECONDS=20
# Maximum effective value is 600 seconds.
KINDLY_NODRIVER_RETRY_ATTEMPTS=3
KINDLY_NODRIVER_RETRY_BACKOFF_SECONDS=0.5
KINDLY_NODRIVER_SNAP_BACKOFF_MULTIPLIER=3.0
# Pooled Chromium reuse (shared state across requests, see README).
KINDLY_NODRIVER_REUSE_BROWSER=1
KINDLY_NODRIVER_BROWSER_POOL_SIZE=1
KINDLY_NODRIVER_ACQUIRE_TIMEOUT_SECONDS=30
# Optional remote debugging port range, e.g. "45000-45100"
KINDLY_NODRIVER_PORT_RANGE=

# nodriver sandbox (Chrome sandbox often breaks in WSL/Docker/headless)
# - Default: disabled in the worker for reliability
# - Set to 1 to re-enable sandbox (more secure, may break in containers)
KINDLY_NODRIVER_SANDBOX=0
